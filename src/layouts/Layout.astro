---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Bureau Veritas Acoustics, Vibration & Occupational Hygiene — noise consultants and acoustic consultants serving the UK.", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const defaultOgImage = new URL(`${base}images/solar-renewables.jpg`, Astro.site).href;
const ogImg = ogImage || defaultOgImage;

const services = [
  { href: 'environmental-noise', label: 'Environmental Noise' },
  { href: 'occupational-noise', label: 'Occupational Noise' },
  { href: 'pipework-vibration', label: 'Pipework Vibration' },
  { href: 'aiv-fiv', label: 'AIV & FIV' },
  { href: 'hand-arm-whole-body-vibration', label: 'Hand-Arm & Whole-Body Vibration' },
  { href: 'building-acoustics', label: 'Building Acoustics' },
  { href: 'occupational-hygiene', label: 'Occupational Hygiene' },
  { href: 'training', label: 'Training' },
];

function isActive(href: string) {
  const full = `${base}${href}`.replace(/\/$/, '');
  return currentPath === full || currentPath === full + '/';
}
const isHome = currentPath === base.replace(/\/$/, '') || currentPath === base.replace(/\/$/, '') + '/';
const isServicePage = services.some(s => isActive(s.href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00049E" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:site_name" content="Bureau Veritas AVOH" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImg} />
    <!-- JSON-LD Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Bureau Veritas AVOH",
      "description": "Acoustics, Vibration & Occupational Hygiene specialist consultancy",
      "url": new URL(base, Astro.site).href,
      "parentOrganization": {
        "@type": "Organization",
        "name": "Bureau Veritas UK Ltd",
        "url": "https://www.bureauveritas.co.uk"
      },
      "areaServed": "United Kingdom",
      "address": [
        { "@type": "PostalAddress", "addressLocality": "Glasgow", "addressCountry": "GB" },
        { "@type": "PostalAddress", "addressLocality": "Aberdeen", "addressCountry": "GB" },
        { "@type": "PostalAddress", "addressLocality": "Manchester", "addressCountry": "GB" },
        { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" }
      ],
      "telephone": "0345 600 1828",
      "knowsAbout": ["Noise Impact Assessment", "Acoustic Consultancy", "Pipework Vibration", "Occupational Hygiene", "Sound Insulation Testing", "Building Acoustics"]
    })} />
  </head>
  <body class="font-sans text-bv-dark bg-white">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:bg-bv-teal focus:text-white focus:px-4 focus:py-2 focus:rounded-md">
      Skip to content
    </a>
    <header class="bg-bv-navy text-white sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
        <div class="flex items-center justify-between h-20 sm:h-24">
          <a href={`${base}`} class="flex items-center gap-3 hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal transition-opacity">
            <img src={`${base}images/bv-logo-white.png`} alt="Bureau Veritas logo" class="h-14 sm:h-20 w-auto" />
            <span class="text-xl font-bold tracking-tight hidden sm:inline">AVOH</span>
          </a>
          <button
            id="mobile-menu-btn"
            type="button"
            class="lg:hidden p-3 rounded-md hover:bg-bv-accent/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div class="hidden lg:flex items-center gap-1">
            <a href={`${base}`} class:list={["px-3 py-2 text-sm transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal rounded", isHome ? "text-bv-teal font-semibold" : "hover:text-bv-teal"]}>Home</a>
            <div class="relative group">
              <button
                type="button"
                class:list={["px-3 py-2 text-sm transition-colors flex items-center gap-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal rounded", isServicePage ? "text-bv-teal font-semibold" : "hover:text-bv-teal"]}
                aria-haspopup="true"
                aria-expanded="false"
              >
                Services
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="absolute left-0 top-full pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200">
                <div class="bg-white text-bv-dark rounded-lg shadow-xl border border-gray-100 py-2 w-72" role="menu">
                  {services.map((s) => (
                    <a
                      href={`${base}${s.href}`}
                      class:list={["block px-4 py-2.5 text-sm transition-colors focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-bv-navy", isActive(s.href) ? "bg-bv-navy/10 text-bv-navy font-semibold" : "hover:bg-bv-navy/5 hover:text-bv-navy"]}
                      role="menuitem"
                    >
                      {s.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <a href={`${base}contact`} class:list={["ml-2 px-4 py-2 text-sm rounded-md transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal", isActive('contact') ? "bg-white text-bv-navy font-semibold" : "bg-bv-teal text-white hover:bg-bv-teal/90"]}>Contact Us</a>
          </div>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="lg:hidden hidden pb-4" aria-label="Mobile navigation">
          <a href={`${base}`} class:list={["block px-3 py-3 text-sm rounded", isHome ? "text-bv-teal font-semibold" : "hover:text-bv-teal"]}>Home</a>
          <div class="border-t border-white/10 my-2"></div>
          <p class="px-3 py-1 text-xs uppercase tracking-wider text-white/50">Services</p>
          {services.map((s) => (
            <a href={`${base}${s.href}`} class:list={["block px-3 py-3 text-sm rounded", isActive(s.href) ? "text-bv-teal font-semibold" : "hover:text-bv-teal"]}>
              {s.label}
            </a>
          ))}
          <div class="border-t border-white/10 my-2"></div>
          <a href={`${base}contact`} class="block px-3 py-3 text-sm text-bv-teal font-semibold">Contact Us</a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <!-- Back to top -->
    <button
      id="back-to-top"
      type="button"
      class="fixed bottom-6 right-6 z-40 hidden w-10 h-10 bg-bv-navy text-white rounded-full shadow-lg hover:bg-bv-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal transition-all items-center justify-center"
      aria-label="Back to top"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
    </button>

    <footer class="text-white">
      <div class="bg-[#1a1fbd]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
              <h3 class="text-lg font-bold mb-4">Bureau Veritas AVOH</h3>
              <p class="text-sm text-white/80 leading-relaxed">Acoustics, Vibration & Occupational Hygiene specialists. Trusted, independent consultancy services across the UK and worldwide.</p>
              <p class="text-sm text-white/80 mt-3">Tel: 0345 600 1828</p>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-4">Our Services</h3>
              <ul class="space-y-2 text-sm">
                {services.map((s) => (
                  <li><a href={`${base}${s.href}`} class="text-white/80 hover:text-bv-teal focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal transition-colors">{s.label}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-lg font-bold mb-4">UK Offices</h3>
              <ul class="space-y-2 text-sm text-white/80">
                <li><a href="https://share.google/NK4iuTgNJ33LAEpI7" target="_blank" rel="noopener noreferrer" class="hover:text-bv-teal transition-colors">Glasgow</a></li>
                <li><a href="https://share.google/IoloClrnuO6GaNAly" target="_blank" rel="noopener noreferrer" class="hover:text-bv-teal transition-colors">Aberdeen</a></li>
                <li><a href="https://share.google/CWUT0qPBah9tWfgJf" target="_blank" rel="noopener noreferrer" class="hover:text-bv-teal transition-colors">Manchester</a></li>
                <li><a href="https://share.google/kt2I5vJoCrv9nIyng" target="_blank" rel="noopener noreferrer" class="hover:text-bv-teal transition-colors">London</a></li>
              </ul>
              <div class="mt-4">
                <a href={`${base}contact`} class="text-bv-teal hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-teal transition-colors text-sm font-semibold">Get in touch &rarr;</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-bv-navy">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-center text-xs text-white/50">
          &copy; {new Date().getFullYear()} Bureau Veritas UK Ltd. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        menuBtn.setAttribute('aria-expanded', String(open));
      });

      // Back to top button
      const topBtn = document.getElementById('back-to-top');
      if (topBtn) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            topBtn.classList.remove('hidden');
            topBtn.classList.add('flex');
          } else {
            topBtn.classList.add('hidden');
            topBtn.classList.remove('flex');
          }
        }, { passive: true });
        topBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
