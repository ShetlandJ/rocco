---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  cta?: { text: string; href: string };
  overlay?: boolean;
}

const { title, subtitle, image, imageAlt = '', cta, overlay = true } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="relative bg-bv-navy text-white overflow-hidden">
  {image && (
    <img
      src={`${base}images/${image}`}
      alt={imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  )}
  {overlay && <div class="absolute inset-0 bg-bv-navy/75"></div>}
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6">{title}</h1>
      {subtitle && <p class="text-lg sm:text-xl text-white/80 leading-relaxed mb-8">{subtitle}</p>}
      {cta && (
        <a
          href={cta.href}
          class="inline-block px-6 py-3 bg-bv-teal text-white font-semibold rounded-md hover:bg-bv-teal/90 transition-colors"
        >
          {cta.text}
        </a>
      )}
    </div>
  </div>
</section>
