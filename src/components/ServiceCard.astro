---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, href, image, imageAlt = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}${href}`}
  class="group block bg-white rounded-lg shadow-md hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bv-navy transition-all duration-300 overflow-hidden border border-gray-100"
>
  {image && (
    <div class="h-48 overflow-hidden">
      <img
        src={`${base}images/${image}`}
        alt={imageAlt}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6">
    <h3 class="text-lg font-bold text-bv-navy group-hover:text-bv-accent transition-colors mb-2">{title}</h3>
    <p class="text-sm text-gray-600 leading-relaxed mb-3">{description}</p>
    <span class="text-bv-teal text-sm font-semibold group-hover:underline">Learn more &rarr;</span>
  </div>
</a>
