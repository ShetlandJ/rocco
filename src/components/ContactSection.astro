---
interface Props {
  heading?: string;
  text?: string;
}

const { heading = "Get in Touch", text = "Contact our team to discuss your acoustics, vibration or occupational hygiene requirements." } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="bg-bv-navy text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">{heading}</h2>
    <p class="text-white/70 max-w-2xl mx-auto mb-8">{text}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href={`${base}contact`}
        class="px-6 py-3 bg-bv-teal text-white font-semibold rounded-md hover:bg-bv-teal/90 transition-colors"
      >
        Contact Us
      </a>
      <span id="email-link" class="text-white/60 text-sm"></span>
    </div>
  </div>
</section>

<script>
  const el = document.getElementById('email-link');
  if (el) {
    const u = 'rocco.giudice';
    const d = 'bureauveritas.com';
    el.innerHTML = `or email <a href="mai${''}lto:${u}@${d}" class="text-bv-teal hover:underline">${u}@${d}</a>`;
  }
</script>
